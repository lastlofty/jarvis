# ============================================
# Jarvis AI Agent — конфигурация
# Скопируйте этот файл в .env и заполните значения
# ============================================

# --- Выбор модели ---
# Активный провайдер LLM: glm (основной, бесплатный) | gemini | ollama
LLM_PROVIDER=glm

# --- GLM (Zhipu AI) — основная модель, бесплатная ---
# Ключ: https://open.bigmodel.cn/  (модель glm-4-flash бесплатна)
GLM_API_KEY=
GLM_MODEL=glm-4-flash
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# Глубокое мышление (reasoning, как у DeepSeek): модель рассуждает, потом отвечает.
GLM_THINKING=false
GLM_THINKING_MODEL=glm-4.5-flash

# --- Gemini (Google) ---
# Бесплатный ключ: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# --- Ollama (локальные модели, офлайн) ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# --- RAG (база знаний) ---
RAG_ENABLED=true
RAG_TOP_K=3
RAG_DB_PATH=./data/rag_store.pkl
# Семантический поиск через эмбеддинги GLM (иначе TF-IDF, офлайн)
RAG_EMBEDDINGS=false
EMBEDDING_MODEL=embedding-3

# --- Долговременная память (между сессиями) ---
MEMORY_ENABLED=true
MEMORY_DB_PATH=./data/memory_store.pkl
MEMORY_TOP_K=3

# --- История чатов (множественные диалоги) ---
CHATS_DB_PATH=./data/chats.db

# --- Автообновление (GitHub Releases) ---
UPDATE_CHECK=true
UPDATE_REPO=lastlofty/jarvis

# --- Плагины и MCP ---
PLUGINS_DIR=./plugins
MCP_ENABLED=false
MCP_CONFIG_PATH=./mcp_servers.json

# --- Голос ---
# Озвучка ответов (TTS, офлайн через pyttsx3)
TTS_ENABLED=false
# Модель для распознавания речи (STT). Скачать: https://alphacephei.com/vosk/models
# Нужны пакеты: pip install vosk sounddevice
VOSK_MODEL_PATH=./models/vosk-model-small-ru

# --- Трей / хоткей / wake-word ---
# Глобальный хоткей показать/скрыть окно (нужен пакет keyboard)
GLOBAL_HOTKEY=ctrl+alt+j
# Активация по слову (нужны vosk + sounddevice + модель)
WAKE_WORD_ENABLED=false
WAKE_WORD=джарвис

# --- Сервер (удалённый доступ для мобильного приложения) ---
HOST=0.0.0.0
PORT=8000
# Сгенерируйте секрет: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_TOKEN=change_me_to_random_secret

# --- Безопасность ---
# Папка, в пределах которой агенту разрешено создавать/удалять файлы.
# Пусто = рабочий стол текущего пользователя.
SAFE_ROOT=
REQUIRE_CONFIRM_DELETE=true

# --- База данных ---
DB_PATH=./data/jarvis.db

# --- Observer (учёт времени в приложениях) ---
OBSERVER_INTERVAL=2.0
ENABLE_OBSERVER=true

# --- Логи ---
LOG_LEVEL=INFO
LOG_FILE=./data/jarvis.log
